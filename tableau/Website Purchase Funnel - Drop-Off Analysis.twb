      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1pzh17a09qbhtj1cnewkw09l2obj].[usr:Calculation_0972025664700428:qk]&quot;' value='SESSIONS' />
          <alias key='&quot;[federated.1pzh17a09qbhtj1cnewkw09l2obj].[usr:Calculation_0972025665368078:qk:2]&quot;' value='STAGE DROP-OFF %' />
        </aliases>
      </column>
      <column caption='Total Sessions' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_0972025655394304]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [stage_name (dim_stages.csv)] = &quot;awareness&quot; THEN [session_id] END&#13;&#10;)' />
      </column>
      <column caption='Total Users' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_0972025655652353]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [stage_name (dim_stages.csv)] = &quot;awareness&quot; THEN [user_id] END&#13;&#10;)' />
      </column>
      <column caption='Total Purchasing Sessions' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_0972025655717890]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [stage_name (dim_stages.csv)] = &quot;purchase&quot; THEN [session_id] END&#13;&#10;)' />
      </column>
      <column caption='Total Purchasing Users' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_0972025655861251]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [stage_name (dim_stages.csv)] = &quot;purchase&quot; THEN [user_id (dim_users.csv)] END&#13;&#10;)' />
      </column>
      <column caption='Session CVR' datatype='real' default-format='p0.0%' name='[Calculation_0972025661812740]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0972025655717890]/[Calculation_0972025655394304]' />
      </column>
      <column caption='True User CVR' datatype='real' default-format='p0.0%' name='[Calculation_0972025661894661]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0972025655861251] / [Calculation_0972025655652353]' />
      </column>
      <column caption='Total Revenue (All)' datatype='real' default-format='n&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Calculation_0972025662377990]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue])' />
      </column>
      <column caption='Total Revenue (Paid)' datatype='real' default-format='n&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Calculation_0972025662468103]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [traffic_source] IN (&quot;paid&quot;, &quot;social&quot;, &quot;email&quot;) &#13;&#10;THEN [revenue] END&#13;&#10;)' />
      </column>
      <column caption='AOV' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Calculation_0972025663172616]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0972025662377990] / [Calculation_0972025655717890]' />
      </column>
      <column caption='Revenue per Session' datatype='real' default-format='c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00' name='[Calculation_0972025663344649]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0972025662377990]/[Calculation_0972025655394304]' />
      </column>
      <column caption='Total Budget' datatype='integer' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Calculation_0972025663451146]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF {FIXED [campaign_name (dim_campaigns.csv)] : COUNTD([session_id])} &gt; 0&#13;&#10;THEN [budget] END&#13;&#10;)' />
      </column>
      <column caption='ROAS' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_0972025663778827]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0972025662468103]/[Calculation_0972025663451146]' />
